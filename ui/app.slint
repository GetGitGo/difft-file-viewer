import { VerticalBox, HorizontalBox, ListView } from "std-widgets.slint";

export struct TextSegment {
    text: string,
    color: brush,
    bold: bool,
    italic: bool,
    x-offset: length,
}

export struct DiffLine {
    lhs-novel: bool,
    rhs-novel: bool,
    lhs-line: int,
    rhs-line: int,
    center-line: int,
    lhs-selected: bool,
    rhs-selected: bool,
    center-selected: bool,
    lhs-show-apply: bool,
    rhs-show-apply: bool,
    center-show-delete: bool,
    center-show-move: bool,
    lhs-plain-text: string,
    rhs-plain-text: string,
    center-plain-text: string,
    lhs-plain-color: brush,
    rhs-plain-color: brush,
    center-plain-color: brush,
    lhs-content-width: length,
    rhs-content-width: length,
    center-content-width: length,
    lhs-segments: [TextSegment],
    rhs-segments: [TextSegment],
    center-segments: [TextSegment],
}

export enum DiffState {
    idle,
    diffing,
    diffed,
}

component PathLabel inherits Rectangle {
    in property <string> path: "";
    in property <length> text-gutter: 4px;

    background: #44475a;
    horizontal-stretch: 1;
    min-width: 1px;

    Text {
        text: root.path == "" ? "—" : root.path;
        color: #f8f8f2;
        font-size: 12px;
        horizontal-alignment: left;
        vertical-alignment: center;
        overflow: elide;
        x: root.text-gutter;
        width: parent.width - 2 * root.text-gutter;
    }
}

enum ActionButtonTone {
    yellow,
    red,
}

component ActionButton inherits Rectangle {
    in property <string> label: "Apply";
    in property <ActionButtonTone> tone: ActionButtonTone.yellow;
    callback clicked();

    width: 42px;
    height: 17px;

    private property <brush> shadow-color: root.tone == ActionButtonTone.red ? #7a1515 : #9a7b00;
    private property <brush> normal-face: root.tone == ActionButtonTone.red ? #ff5555 : #ffea00;
    private property <brush> hover-face: root.tone == ActionButtonTone.red ? #ff7979 : #fff176;
    private property <brush> pressed-face: root.tone == ActionButtonTone.red ? #e53935 : #f9d423;
    private property <brush> highlight-color: root.tone == ActionButtonTone.red ? #ffb3b3 : #fff9c4;
    private property <brush> edge-color: root.tone == ActionButtonTone.red ? #c62828 : #e6b800;
    private property <brush> face-color: action-touch.pressed ? root.pressed-face : (action-touch.has-hover ? root.hover-face : root.normal-face);
    private property <length> face-y: action-touch.pressed ? 1px : 0px;

    Rectangle {
        x: 1px;
        y: 2px;
        width: parent.width - 1px;
        height: parent.height - 1px;
        background: root.shadow-color;
        border-radius: 4px;
    }

    face := Rectangle {
        y: root.face-y;
        width: parent.width - 2px;
        height: parent.height - 2px;
        background: root.face-color;
        border-radius: 4px;

        Rectangle {
            height: 45%;
            background: root.highlight-color;
            border-radius: 4px;
        }

        Rectangle {
            y: parent.height - 2px;
            height: 2px;
            background: root.edge-color;
            border-radius: 2px;
        }
    }

    action-touch := TouchArea {
        clicked => {
            root.clicked();
        }
    }

    Text {
        text: root.label;
        color: #1a1400;
        font-size: 10px;
        font-weight: 700;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

component ApplyButton inherits ActionButton {
    label: "Apply";
}

component CodeSide inherits Rectangle {
    in property <int> line-number: -1;
    in property <string> plain-text;
    in property <brush> plain-color;
    in property <[TextSegment]> segments;
    in property <bool> novel;
    in property <bool> selected: false;
    in property <bool> show-apply: false;
    in property <bool> show-center-delete: false;
    in property <bool> show-center-move: false;
    in property <bool> gutter-enabled: true;
    in property <bool> insert-target: false;
    in property <length> line-height: 20px;
    in property <length> code-font-size: 12px;
    in property <brush> gutter-line-color: #6272a4;
    in property <brush> gutter-selected-color: #bd93f9;
    in property <brush> gutter-insert-color: #50fa7b;
    in property <length> gutter-width: 44px;
    in property <length> code-scroll-x: 0px;
    callback gutter-clicked();
    callback apply-clicked();
    callback delete-clicked();
    callback move-clicked();
    callback horizontal-scroll(delta: length);

    pure function is-horizontal-scroll(event: PointerScrollEvent) -> bool {
        (event.delta-x < 0px ? -event.delta-x : event.delta-x) > 0px
            && (event.delta-x < 0px ? -event.delta-x : event.delta-x)
                >= (event.delta-y < 0px ? -event.delta-y : event.delta-y)
    }

    private property <bool> insert-hovered: root.insert-target && insert-row-touch.has-hover;
    private property <brush> row-background: root.selected ? #44475a
        : (root.insert-hovered ? #3d4f44 : (root.novel ? #3b3f52 : #282a36));

    horizontal-stretch: 1;
    min-width: 1px;
    height: root.line-height;
    background: root.row-background;
    clip: true;

    code-panel := Rectangle {
        x: root.gutter-width;
        width: parent.width - root.gutter-width;
        height: root.line-height;
        background: root.row-background;
        clip: true;

        Text {
            x: -root.code-scroll-x;
            height: root.line-height;
            text: root.plain-text;
            color: root.plain-color;
            font-family: "Courier New";
            font-size: root.code-font-size;
            font-weight: 700;
            wrap: no-wrap;
            horizontal-alignment: left;
            vertical-alignment: center;
            visible: root.plain-text != "" && root.segments.length == 0;
        }

        for seg in root.segments: Text {
            x: seg.x-offset * root.code-font-size / 12px - root.code-scroll-x;
            height: root.line-height;
            text: seg.text;
            color: seg.color;
            font-family: "Courier New";
            font-size: root.code-font-size;
            font-weight: 700;
            font-italic: seg.italic;
            vertical-alignment: center;
        }

        if (!root.insert-target): code-scroll-touch := TouchArea {
            width: parent.width;
            height: parent.height;

            scroll-event(event) => {
                if (root.is-horizontal-scroll(event)) {
                    root.horizontal-scroll(-event.delta-x);
                    return accept;
                }
                return reject;
            }
        }
    }

    gutter := Rectangle {
        x: 0;
        width: root.gutter-width;
        height: root.line-height;
        background: root.row-background;

        gutter-touch := TouchArea {
            width: parent.width;
            height: parent.height;
            enabled: !root.insert-target && root.gutter-enabled && root.line-number >= 1
                && !root.show-apply && !root.show-center-delete && !root.show-center-move;

            clicked => {
                root.gutter-clicked();
            }
        }

        if (root.insert-hovered): Text {
            x: 0;
            width: 11px;
            height: root.line-height;
            text: "▶";
            color: root.gutter-insert-color;
            font-size: root.code-font-size * 9 / 12;
            font-weight: 700;
            horizontal-alignment: center;
            vertical-alignment: center;
        }

        Text {
            x: root.insert-hovered ? 10px : 0px;
            width: parent.width - 6px - (root.insert-hovered ? 10px : 0px);
            height: root.line-height;
            text: root.line-number >= 1 ? root.line-number : "";
            color: root.insert-hovered ? root.gutter-insert-color : (root.selected ? root.gutter-selected-color : root.gutter-line-color);
            font-family: "Courier New";
            font-size: root.code-font-size;
            font-weight: 700;
            horizontal-alignment: right;
            vertical-alignment: center;
            visible: !root.show-apply && !root.show-center-delete && !root.show-center-move;
        }

        if (root.show-apply): ApplyButton {
            x: 1px;
            y: (root.line-height - 17px) / 2;
            clicked => {
                root.apply-clicked();
            }
        }

        if (root.show-center-delete): ActionButton {
            x: 0px;
            y: (root.line-height - 17px) / 2;
            width: 46px;
            label: "Delete";
            tone: ActionButtonTone.red;
            clicked => {
                root.delete-clicked();
            }
        }

        if (root.show-center-move): ActionButton {
            x: 0px;
            y: (root.line-height - 17px) / 2;
            width: 46px;
            label: "Move";
            tone: ActionButtonTone.yellow;
            clicked => {
                root.move-clicked();
            }
        }
    }

    insert-row-touch := TouchArea {
        width: parent.width;
        height: parent.height;
        enabled: root.insert-target && root.gutter-enabled && root.line-number >= 1;
        mouse-cursor: pointer;

        clicked => {
            root.gutter-clicked();
        }
    }
}

component DiffCodeScrollView inherits Rectangle {
    in property <length> code-line-height;
    in property <length> code-font-size: 12px;
    in property <length> line-number-width;
    in property <brush> gutter-line-color;
    in property <brush> gutter-selected-color;
    in property <brush> gutter-insert-color;
    in property <bool> triple-pane: false;
    in property <bool> apply-pending: false;
    in property <[DiffLine]> lines;
    in property <length> max-content-width: 0px;
    in-out property <length> code-scroll-x: 0px;
    callback gutter-clicked(row-index: int, lhs-side: bool);
    callback apply-clicked(row-index: int, lhs-side: bool);
    callback center-gutter-clicked(row-index: int);
    callback center-delete-clicked(row-index: int);
    callback center-move-clicked(row-index: int);

    private property <int> column-count: root.triple-pane ? 3 : 2;
    private property <length> scaled-max-content-width: root.max-content-width * root.code-font-size / 12px;
    private property <length> column-code-width: max(0px, list.width / root.column-count - root.line-number-width);
    private property <length> scroll-max-x: max(0px, root.scaled-max-content-width - column-code-width);

    vertical-stretch: 1;
    horizontal-stretch: 1;
    clip: true;
    background: #282a36;

    private property <length> scroll-bottom-padding: root.code-line-height;
    private property <length> scroll-min-y: min(0px, list.visible-height - list.viewport-height - root.scroll-bottom-padding);

    list := ListView {
        width: parent.width;
        height: parent.height - root.scroll-bottom-padding;

        for line[index] in root.lines: HorizontalBox {
            width: list.viewport-width;
            height: root.code-line-height;
            spacing: 0px;
            padding: 0px;

            CodeSide {
                line-height: root.code-line-height;
                code-font-size: root.code-font-size;
                gutter-line-color: root.gutter-line-color;
                gutter-selected-color: root.gutter-selected-color;
                gutter-insert-color: root.gutter-insert-color;
                gutter-width: root.line-number-width;
                code-scroll-x: root.code-scroll-x;
                line-number: line.lhs-line;
                plain-text: line.lhs-plain-text;
                plain-color: line.lhs-plain-color;
                segments: line.lhs-segments;
                novel: line.lhs-novel;
                selected: line.lhs-selected;
                show-apply: line.lhs-show-apply && !root.apply-pending;
                horizontal-scroll(delta) => {
                    root.scroll-code-horizontal(delta);
                }
                gutter-clicked => {
                    root.gutter-clicked(index, true);
                }
                apply-clicked => {
                    root.apply-clicked(index, true);
                }
            }

            if (root.triple-pane): CodeSide {
                line-height: root.code-line-height;
                code-font-size: root.code-font-size;
                gutter-line-color: root.gutter-line-color;
                gutter-selected-color: root.gutter-selected-color;
                gutter-insert-color: root.gutter-insert-color;
                gutter-width: root.line-number-width;
                code-scroll-x: root.code-scroll-x;
                line-number: line.center-line;
                plain-text: line.center-plain-text;
                plain-color: line.center-plain-color;
                segments: line.center-segments;
                novel: false;
                selected: line.center-selected;
                show-center-delete: line.center-show-delete && !root.apply-pending;
                show-center-move: line.center-show-move && !root.apply-pending;
                insert-target: root.apply-pending && line.center-line >= 1;
                gutter-enabled: line.center-line >= 1;
                horizontal-scroll(delta) => {
                    root.scroll-code-horizontal(delta);
                }
                gutter-clicked => {
                    root.center-gutter-clicked(index);
                }
                delete-clicked => {
                    root.center-delete-clicked(index);
                }
                move-clicked => {
                    root.center-move-clicked(index);
                }
            }

            CodeSide {
                line-height: root.code-line-height;
                code-font-size: root.code-font-size;
                gutter-line-color: root.gutter-line-color;
                gutter-selected-color: root.gutter-selected-color;
                gutter-insert-color: root.gutter-insert-color;
                gutter-width: root.line-number-width;
                code-scroll-x: root.code-scroll-x;
                line-number: line.rhs-line;
                plain-text: line.rhs-plain-text;
                plain-color: line.rhs-plain-color;
                segments: line.rhs-segments;
                novel: line.rhs-novel;
                selected: line.rhs-selected;
                show-apply: line.rhs-show-apply && !root.apply-pending;
                horizontal-scroll(delta) => {
                    root.scroll-code-horizontal(delta);
                }
                gutter-clicked => {
                    root.gutter-clicked(index, false);
                }
                apply-clicked => {
                    root.apply-clicked(index, false);
                }
            }
        }
    }

    changed max-content-width => {
        root.code-scroll-x = min(root.code-scroll-x, root.scroll-max-x);
    }

    changed code-font-size => {
        root.code-scroll-x = min(root.code-scroll-x, root.scroll-max-x);
    }

    changed scroll-max-x => {
        root.code-scroll-x = min(root.code-scroll-x, root.scroll-max-x);
    }

    public function reset-scroll() {
        list.viewport-y = 0px;
        root.code-scroll-x = 0px;
    }

    public function scroll-code-left() {
        root.code-scroll-x = max(0px, root.code-scroll-x - root.code-font-size * 48 / 12);
    }

    public function scroll-code-right() {
        root.code-scroll-x = min(root.scroll-max-x, root.code-scroll-x + root.code-font-size * 48 / 12);
    }

    public function scroll-code-horizontal(delta: length) {
        root.code-scroll-x = min(root.scroll-max-x, max(0px, root.code-scroll-x + delta));
    }

    public function page-up() {
        list.viewport-y = min(0px, list.viewport-y + list.visible-height);
    }

    public function page-down() {
        list.viewport-y = max(scroll-min-y, list.viewport-y - list.visible-height);
    }

    public function half-page-up() {
        list.viewport-y = min(0px, list.viewport-y + list.visible-height / 2);
    }

    public function half-page-down() {
        list.viewport-y = max(scroll-min-y, list.viewport-y - list.visible-height / 2);
    }

    public function scroll-to-top() {
        list.viewport-y = 0px;
    }

    public function scroll-to-bottom() {
        list.viewport-y = scroll-min-y;
    }
}

export component MainWindow inherits Window {
    preferred-width: 2560px;
    preferred-height: 1440px;
    title: "difft-file-viewer";
    no-frame: true;
    resize-border-width: 0px;
    icon: @image-url("../assets/icons/icon-256.png");
    background: #282a36;
    forward-focus: root-focus;

    callback gutter-clicked(row-index: int, lhs-side: bool);
    callback apply-clicked(row-index: int, lhs-side: bool);
    callback center-gutter-clicked(row-index: int);
    callback center-delete-clicked(row-index: int);
    callback center-move-clicked(row-index: int);
    callback apply-cancel-requested();
    callback apply-undo-requested();
    callback quit-requested();

    in-out property <length> toolbar-height: 16px;
    in-out property <length> toolbar-gap: 1px;
    in-out property <length> code-font-size: 12px;
    in-out property <brush> gutter-line-color: #6272a4;
    in-out property <brush> gutter-selected-color: #bd93f9;
    in-out property <brush> gutter-insert-color: #50fa7b;
    private property <length> code-line-height: root.code-font-size + 8px;
    private property <length> line-number-width: root.code-font-size * 48 / 12;
    private property <bool> show-status-bar: root.status-text != "" || root.file-info != "";
    private property <length> status-bar-height: 72px;

    in-out property <string> path-a: "";
    in-out property <string> path-b: "";
    in-out property <string> path-c: "";
    in-out property <bool> triple-pane: false;
    in-out property <bool> apply-pending: false;
    in-out property <DiffState> diff-state: DiffState.idle;
    in-out property <string> status-text: "Select file A and file B to compare.";
    in-out property <string> file-info: "";
    in-out property <[DiffLine]> lines;
    in-out property <length> code-scroll-x: 0px;
    in-out property <length> max-content-width: 0px;
    private property <bool> vim-pending-g: false;

    changed diff-state => {
        if (root.diff-state == DiffState.diffed) {
            root-focus.focus();
        }
    }

    public function focus-diff-panel() {
        root-focus.focus();
    }

    public function reset-diff-scroll() {
        code-scroll.reset-scroll();
    }

    public function scroll-code-left() {
        code-scroll.scroll-code-left();
    }

    public function scroll-code-right() {
        code-scroll.scroll-code-right();
    }

    public function scroll-code-horizontal(delta: length) {
        code-scroll.scroll-code-horizontal(delta);
    }

    pure function is-scroll-code-left(event: KeyEvent) -> bool {
        event.text == "h" && !event.modifiers.shift && !root.vim-modifiers(event)
    }

    pure function is-scroll-code-right(event: KeyEvent) -> bool {
        event.text == "l" && !event.modifiers.shift && !root.vim-modifiers(event)
    }

    // Physical Ctrl on macOS is reported as meta; Ctrl+letter may be a control character.
    pure function vim-modifiers(event: KeyEvent) -> bool {
        event.modifiers.control || event.modifiers.meta
    }

    pure function is-vim-page-up(event: KeyEvent) -> bool {
        event.text == Key.PageUp
            || event.text == "\u{0002}"
            || (root.vim-modifiers(event) && (event.text == "b" || event.text == "B"))
    }

    pure function is-vim-page-down(event: KeyEvent) -> bool {
        event.text == Key.PageDown
            || event.text == "\u{0006}"
            || (root.vim-modifiers(event) && (event.text == "f" || event.text == "F"))
    }

    pure function is-vim-half-page-up(event: KeyEvent) -> bool {
        event.text == "\u{0015}"
            || (root.vim-modifiers(event) && (event.text == "u" || event.text == "U"))
    }

    pure function is-vim-half-page-down(event: KeyEvent) -> bool {
        event.text == "\u{0004}"
            || (root.vim-modifiers(event) && (event.text == "d" || event.text == "D"))
    }

    pure function is-vim-go-bottom(event: KeyEvent) -> bool {
        event.text == "G"
            || (event.text == "g" && event.modifiers.shift)
    }

    pure function is-vim-go-top-g(event: KeyEvent) -> bool {
        event.text == "g"
            && !event.modifiers.shift
            && !root.vim-modifiers(event)
    }

    pure function is-apply-undo(event: KeyEvent) -> bool {
        event.text == "\u{001a}"
            || (event.text == "z" && root.vim-modifiers(event) && !event.modifiers.shift)
            || (event.text == "u" && !event.modifiers.shift && !root.vim-modifiers(event))
    }

    pure function is-quit(event: KeyEvent) -> bool {
        event.text == "q" && !event.modifiers.shift && !root.vim-modifiers(event)
    }

    pure function is-code-font-larger(event: KeyEvent) -> bool {
        root.vim-modifiers(event) && (event.text == "=" || event.text == "+")
    }

    pure function is-code-font-smaller(event: KeyEvent) -> bool {
        root.vim-modifiers(event) && event.text == "-"
    }

    root-focus := FocusScope {
        width: 100%;
        height: 100%;

        key-pressed(event) => {
            if (root.is-scroll-code-left(event)) {
                root.scroll-code-left();
                root.vim-pending-g = false;
                return accept;
            }
            if (root.is-scroll-code-right(event)) {
                root.scroll-code-right();
                root.vim-pending-g = false;
                return accept;
            }
            if (root.is-vim-page-up(event)) {
                code-scroll.page-up();
                return accept;
            }
            if (root.is-vim-page-down(event)) {
                code-scroll.page-down();
                return accept;
            }
            if (root.is-vim-half-page-up(event)) {
                code-scroll.half-page-up();
                return accept;
            }
            if (root.is-vim-half-page-down(event)) {
                code-scroll.half-page-down();
                return accept;
            }
            if (root.triple-pane && root.is-apply-undo(event)) {
                root.apply-undo-requested();
                root.vim-pending-g = false;
                return accept;
            }
            if (event.text == Key.Home) {
                code-scroll.scroll-to-top();
                root.vim-pending-g = false;
                return accept;
            }
            if (event.text == Key.End) {
                code-scroll.scroll-to-bottom();
                root.vim-pending-g = false;
                return accept;
            }
            if (root.is-vim-go-bottom(event)) {
                code-scroll.scroll-to-bottom();
                root.vim-pending-g = false;
                return accept;
            }
            if (root.is-vim-go-top-g(event)) {
                if (root.vim-pending-g) {
                    code-scroll.scroll-to-top();
                    root.vim-pending-g = false;
                } else {
                    root.vim-pending-g = true;
                }
                return accept;
            }
            root.vim-pending-g = false;
            if (event.text == Key.Escape) {
                if (root.apply-pending) {
                    root.apply-cancel-requested();
                } else {
                    root.gutter-clicked(-1, false);
                }
                return accept;
            }
            if (root.is-quit(event)) {
                root.quit-requested();
                return accept;
            }
            if (root.is-code-font-larger(event)) {
                root.code-font-size = min(24px, root.code-font-size + 1px);
                root.vim-pending-g = false;
                return accept;
            }
            if (root.is-code-font-smaller(event)) {
                root.code-font-size = max(8px, root.code-font-size - 1px);
                root.vim-pending-g = false;
                return accept;
            }
            return reject;
        }

        diff-panel := Rectangle {
            width: 100%;
            height: 100%;

            content-row := Rectangle {
                y: root.toolbar-height;
                width: parent.width;
                height: parent.height - root.toolbar-height;
                clip: true;
                background: #282a36;

                code-scroll := DiffCodeScrollView {
                    width: parent.width;
                    height: parent.height - (root.show-status-bar ? root.status-bar-height : 0px);
                    code-line-height: root.code-line-height;
                    code-font-size: root.code-font-size;
                    line-number-width: root.line-number-width;
                    gutter-line-color: root.gutter-line-color;
                    gutter-selected-color: root.gutter-selected-color;
                    gutter-insert-color: root.gutter-insert-color;
                    triple-pane: root.triple-pane;
                    apply-pending: root.apply-pending;
                    lines: root.lines;
                    code-scroll-x <=> root.code-scroll-x;
                    max-content-width: root.max-content-width;
                    gutter-clicked(row-index, lhs-side) => {
                        root.gutter-clicked(row-index, lhs-side);
                    }
                    apply-clicked(row-index, lhs-side) => {
                        root.apply-clicked(row-index, lhs-side);
                    }
                    center-gutter-clicked(row-index) => {
                        root.center-gutter-clicked(row-index);
                    }
                    center-delete-clicked(row-index) => {
                        root.center-delete-clicked(row-index);
                    }
                    center-move-clicked(row-index) => {
                        root.center-move-clicked(row-index);
                    }
                }

                status-bar := Rectangle {
                    visible: root.show-status-bar;
                    width: parent.width;
                    height: root.status-bar-height;
                    y: parent.height - self.height;
                    background: #21222c;
                    clip: true;

                    VerticalBox {
                        padding-left: 4px;
                        padding-right: 4px;
                        padding-top: 2px;
                        padding-bottom: 2px;
                        spacing: 2px;

                        Text {
                            text: root.status-text;
                            color: #f8f8f2;
                            font-size: 12px;
                            wrap: word-wrap;
                            visible: root.status-text != "";
                        }

                        Text {
                            text: root.file-info;
                            color: #bd93f9;
                            font-size: 12px;
                            wrap: word-wrap;
                            visible: root.file-info != "";
                        }
                    }
                }
            }

            header-row := HorizontalBox {
                y: 0;
                width: parent.width;
                height: root.toolbar-height;
                padding: 0px;
                spacing: root.toolbar-gap;
                z: 2;

                PathLabel {
                    height: root.toolbar-height;
                    path: root.path-a;
                }

                if (root.triple-pane): PathLabel {
                    height: root.toolbar-height;
                    path: root.path-c;
                }

                PathLabel {
                    height: root.toolbar-height;
                    path: root.path-b;
                }
            }
        }
    }
}
